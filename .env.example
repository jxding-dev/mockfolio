# ─── Supabase Auth (optional) ───────────────────────────────
# With both values set, the header "로그인" button enables real login
# (passwordless email magic-link + Google OAuth). Leave them empty and the
# app runs in fully-free guest mode — no login, nothing breaks.
#
# Where to find: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# Feedback email (Vercel serverless function)
# For Naver SMTP, enable SMTP/IMAP in Naver Mail settings first.
SMTP_HOST=smtp.naver.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=YOUR_NAVER_ID@naver.com
SMTP_PASS=YOUR_SMTP_PASSWORD
FEEDBACK_TO_EMAIL=vlsptm1130@naver.com
FEEDBACK_FROM_EMAIL=YOUR_NAVER_ID@naver.com
